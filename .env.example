# Copy to .env and adjust. Scripts read PRIVATE_AI_AUTH_TOKEN; the gateway reads all of these.

# Bearer token the gateway requires on every request. CHANGE THIS for any non-local use.
PRIVATE_AI_AUTH_TOKEN=private-portfolio-token

# Optional: override the audit/log directory (defaults to <project_root>/logs).
# PRIVATE_AI_LOG_DIR=

# Optional: output token caps (defaults shown).
# PRIVATE_AI_MAX_OUTPUT_TOKENS=4096
# PRIVATE_AI_MAX_OUTPUT_TOKENS_STRATEGY=4096
# PRIVATE_AI_MAX_OUTPUT_TOKENS_ENGINEERING=4096
# PRIVATE_AI_MAX_OUTPUT_TOKENS_OFFSEC=4096
